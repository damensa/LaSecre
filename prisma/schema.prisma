datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  phone         String   @id
  status        String   @default("FREE") // FREE, PAID
  monthlyCount  Int      @default(0)
  lastReset     DateTime @default(now())
  createdAt     DateTime @default(now())
  accountantEmail String?
  stripeCustomerId String? @unique
  fiscalName    String?
  nif           String?
  address       String?
  postalCode    String?
  city          String?
  updatedAt     DateTime @updatedAt
  aeatReminders Boolean  @default(true)
}

model AeatEvent {
  id          String   @id @default(uuid())
  uid         String   @unique
  title       String
  description String?
  dueDate     DateTime
  category    String   // "IVA", "RENDA", "INFORMATIVA"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AeatReminder {
  id                 String   @id @default(uuid())
  userPhone          String
  aeatEventId        String
  sentAt             DateTime @default(now())
  daysBeforeDeadline Int

  @@unique([userPhone, aeatEventId, daysBeforeDeadline])
}

model Receipt {
  id            String   @id @default(uuid())
  userPhone     String
  merchant      String?
  date          String?
  total         Float?
  vat           Float?
  vatPercentage Float?
  baseAmount    Float?
  category      String?
  cif           String?
  invoiceNumber String?
  invoiceType   String?
  imageUrl      String?
  type          String   @default("PURCHASE") // PURCHASE (compra), SALE (venda)
  createdAt     DateTime @default(now())
}

model WebhookEvent {
  messageId String   @id
  timestamp DateTime @default(now())
  status    String   @default("RECEIVED") // RECEIVED, PROCESSING, PROCESSED, ERROR
  errorMessage String?
}

model Message {
  id        String   @id @default(uuid())
  userPhone String
  role      String   // 'user' or 'model'
  content   String
  createdAt DateTime @default(now())
}
