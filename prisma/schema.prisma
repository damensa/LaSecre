datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  phone         String   @id
  status        String   @default("FREE") // FREE, PAID
  monthlyCount  Int      @default(0)
  lastReset     DateTime @default(now())
  createdAt     DateTime @default(now())
  accountantEmail String?
  stripeCustomerId String? @unique
  updatedAt     DateTime @updatedAt
}

model Receipt {
  id            String   @id @default(uuid())
  userPhone     String
  merchant      String?
  date          String?
  total         Float?
  vat           Float?
  category      String?
  imageUrl      String?
  createdAt     DateTime @default(now())
}

model WebhookEvent {
  messageId String   @id
  timestamp DateTime @default(now())
  status    String   @default("RECEIVED") // RECEIVED, PROCESSING, PROCESSED, ERROR
  errorMessage String?
}

model Message {
  id        String   @id @default(uuid())
  userPhone String
  role      String   // 'user' or 'model'
  content   String
  createdAt DateTime @default(now())
}
