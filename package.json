{
  "name": "lasecre",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "npx prisma generate && npx prisma migrate deploy && node dist/index.js",
    "dev": "nodemon --watch \"src/**/*.ts\" --watch .env --exec ts-node src/index.ts",
    "build": "npx prisma generate && tsc",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test:live": "ts-node tests/test-server-live.ts",
    "test:gemini": "ts-node tests/test-gemini-parser.ts",
    "test:stripe": "cross-env NODE_ENV=test ts-node tests/test-stripe-mock.ts",
    "test:business-limit": "ts-node tests/test-business-limit.ts",
    "test:models": "ts-node tests/debug-gemini.ts",
    "test": "npm run test:live && npm run test:gemini && npm run test:business-limit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "nodemailer": "^8.0.4",
    "prisma": "^6.19.2",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/exceljs": "^0.5.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/stripe": "^8.0.416",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
